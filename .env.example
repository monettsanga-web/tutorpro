# Browser-safe public configuration
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id
# Public HTTPS image URL for your official WeChat Pay merchant QR code.
VITE_WECHAT_PAY_QR_URL=https://example.com/your-wechat-pay-qr.png

# Leave empty to use same-browser tab signaling for local demos.
# Use a secure wss:// endpoint in production.
VITE_CLASSROOM_SIGNALING_URL=ws://localhost:8787

# Signaling server settings (server-side only)
PORT=8787
ALLOWED_ORIGINS=http://localhost:5173
