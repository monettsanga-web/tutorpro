# Shared Supabase registration database (browser-safe public values)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Optional classroom chat translation endpoint. The app uses a browser-safe fallback when empty.
VITE_TRANSLATION_API_URL=

# Leave empty to use Supabase Realtime for cross-device classroom signaling.
# Set this only when using a separately hosted secure WebSocket signaling server.
VITE_CLASSROOM_SIGNALING_URL=

# Optional TURN relay for restrictive school/corporate networks.
# Use short-lived credentials from a trusted TURN provider in production.
VITE_CLASSROOM_TURN_URL=
VITE_CLASSROOM_TURN_USERNAME=
VITE_CLASSROOM_TURN_CREDENTIAL=

# Signaling server settings (server-side only)
PORT=8787
ALLOWED_ORIGINS=http://localhost:5173
